# Copy this file to .env and add your Google Gemini API key.
# Get a key at: https://aistudio.google.com/apikey
GOOGLE_API_KEY=-----

# Embeddings: auto | huggingface | google | tfidf
# Use "tfidf" on low-RAM PCs or if HuggingFace/torch fails.
EMBEDDING_MODE=tfidf

# If chat fails with SSL certificate errors on college Wi-Fi, uncomment:
# SSL_VERIFY=false

# Store FAISS index and ML caches on D: drive (saves C: space)
DATA_DRIVE=D:/college-rag-data
